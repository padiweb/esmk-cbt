<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/primary"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ Pengaturan Aplikasi"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hanya untuk Admin / Pengawas"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card: Konfigurasi Server -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KONFIGURASI SERVER"
            android:textSize="11sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL Server (contoh: https://ujian.sekolah.sch.id)"
            android:inputType="textUri"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/et_nama_sekolah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nama Sekolah (tampil di splash screen)"
            android:inputType="textCapWords"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Card: Ubah PIN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UBAH PIN PENGAWAS (opsional)"
            android:textSize="11sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_pin_lama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="PIN lama (kosongkan jika tidak ingin ubah PIN)"
            android:inputType="numberPassword"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/et_pin_baru"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="PIN baru (min. 4 digit)"
            android:inputType="numberPassword"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PIN default: 1234 — Ubah segera setelah install!"
            android:textSize="12sp"
            android:textColor="#E53935"
            android:layout_marginBottom="32dp" />

        <!-- Tombol -->
        <Button
            android:id="@+id/btn_simpan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾 SIMPAN &amp; MASUK"
            android:backgroundTint="@color/primary"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_batal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Batal"
            android:backgroundTint="#E0E0E0"
            android:textColor="#333333"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>
